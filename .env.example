# ─── Supabase ────────────────────────────────────────────────────────────────
# Find these in Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — used by Node scripts only, NEVER expose in the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Secret key — set this in Supabase Edge Function secrets, NOT in .env
# Stripe dashboard → Developers → API keys → Secret key (sk_test_... / sk_live_...)
# Set via: supabase secrets set STRIPE_SECRET_KEY=sk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — generated when you register the webhook endpoint
# Stripe dashboard → Developers → Webhooks → your endpoint → Signing secret
# Set via: supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs for each plan — create these in the Stripe dashboard first
# Stripe dashboard → Products → Add product → Add a price → copy the price ID
# Set via: supabase secrets set STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_ELITE=price_...

# ─── App ─────────────────────────────────────────────────────────────────────
# The public URL of your deployed frontend (used for Stripe redirect URLs)
# Locally: http://localhost:5173
# Production: https://your-domain.com
# Set via: supabase secrets set APP_URL=https://your-domain.com
APP_URL=http://localhost:5173
